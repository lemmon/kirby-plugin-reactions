{
    "name": "lemmon/kirby-reactions",
    "description": "Kirby plugin that collects configurable emoji reactions with append-only storage and privacy-first defaults.",
    "license": "MIT",
    "type": "kirby-plugin",
    "keywords": [
        "kirby",
        "kirby-cms",
        "kirby-plugin",
        "feedback",
        "reactions",
        "emoji",
        "htmx"
    ],
    "authors": [
        {
            "name": "Jakub Pelák",
            "email": "jpelak@gmail.com"
        }
    ],
    "support": {
        "issues": "https://github.com/lemmon/kirby-plugin-reactions/issues",
        "source": "https://github.com/lemmon/kirby-plugin-reactions"
    },
    "require": {
        "getkirby/composer-installer": "^1.2"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.48"
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "getkirby/composer-installer": true
        }
    },
    "extra": {
        "installer-name": "reactions"
    }
}
